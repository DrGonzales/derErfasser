{
	"name": "der Erfasser (VS-Code)",
	// Use a Dockerfile so we can pin --platform=linux/arm64 at build time and install OpenCode.
	// JetBrains does not propagate runArgs platform constraints through its
	// feature layer build, causing amd64/arm64 mismatches at container start.
	"build": {
		"dockerfile": "Dockerfile"
	},
	// Forward the dev server port and the OpenCode web server port.
	// Port 4096 is used by `opencode web` — allows `opencode attach http://localhost:4096`
	// from the host to connect to the container's OpenCode server.
	"forwardPorts": [
		5173,
		4096
	],
	// Install project dependencies after the container is created.
	//"postCreateCommand": "npm install && npx skills experimental_install",
	// Start the OpenCode web server on every container start so it is always reachable
	// from the host via `opencode attach http://localhost:4096`.
	// Runs in the background; logs go to /tmp/opencode-web.log for debugging.
	//"postStartCommand": "opencode web --hostname 0.0.0.0 --port 1234 > /tmp/opencode-web.log 2>&1 &",
	// Bind-mount host OpenCode config and auth into the container so the container
	// shares the same provider credentials and settings as the host.
	// This is required for the `opencode attach` workflow to use host API keys.
	"mounts": [
		"source=${localEnv:HOME}/.config/opencode,target=/home/node/.config/opencode,type=bind,consistency=cached",
		//"source=${localEnv:HOME}/.local/share/opencode,target=/home/node/.local/share/opencode,type=bind,consistency=cached"
	],
	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"eamodio.gitlens",
				"redhat.vscode-yaml",
				"svelte.svelte-vscode"
			]
		}
	},
	"remoteUser": "node"
}