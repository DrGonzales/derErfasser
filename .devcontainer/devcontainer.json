{
    "name": "ubuntu-dev",
    //"image": "pi:5000/devcontainer/ubuntu-dev:20260627-ef11075",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": {
            "JAVA_VERSION": "21-tem",
            "NODE_VERSION": "lts/*",
            "TASK_VERSION": "v3.42.1"
        }
    },
    "updateRemoteUserUID": true,
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack",
                "ms-python.python",
                "ms-vscode.vscode-node-azure-pack",
                "eamodio.gitlens",
                "redhat.vscode-yaml",
                "vmware.vscode-boot-dev-pack",
                "ms-azuretools.vscode-containers",
                "svelte.svelte-vscode",
                "openai.chatgpt-vscode"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh"
            }
        }
    },
    "runArgs": [
        "--group-add",
        "${localEnv:DOCKER_GID:986}"
    ],
    "mounts": [
        "source=${localEnv:HOME}/.gitconfig,target=/home/ubuntu/.gitconfig,type=bind,readonly",
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
        "source=${localEnv:HOME}/.ssh,target=/home/ubuntu/.ssh,type=bind,readonly",
        "source=${localEnv:HOME}/.config/opencode/opencode.json,target=/home/ubuntu/.config/opencode/opencode.json,type=bind,readonly"
    ]
}